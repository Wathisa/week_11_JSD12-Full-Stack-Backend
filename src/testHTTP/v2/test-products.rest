# MongoDB - Products API (v2)
# Base: /api/v2/products
#
# IDs in MongoDB are ObjectIds - replace the placeholder below with a real one
# after running the POST request.
#
# @id = paste-a-real-objectid-here

### Read all products (MongoDB)
GET http://localhost:3002/api/v2/products

### Create a new product (MongoDB)
POST http://localhost:3002/api/v2/products
Content-Type: application/json

{
    "name": "Mongo Product",
    "price": 45000,
    "stock": 12
}

### Update a product (MongoDB) - replace the ObjectId with a real id from POST response
PUT http://localhost:3002/api/v2/products/682aabd62ef0f8ebf2e12345
Content-Type: application/json

{
    "name": "Mongo Product Updated",
    "price": 42000,
    "stock": 9
}

### Delete a product (MongoDB) - replace the ObjectId with a real id from POST response
DELETE http://localhost:3002/api/v2/products/682aabd62ef0f8ebf2e12345
