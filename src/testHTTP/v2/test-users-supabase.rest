# Supabase / PostgreSQL — Users API (v2)
# Base: /api/v2/users/pg
#
# IDs in Supabase are UUIDs — replace the placeholder below with a real one
# after running the POST request.
#
# @id = paste-a-real-uuid-here

### Read all users (Supabase)
GET http://localhost:3002/api/v2/users/pg

### Create a new user (Supabase)
POST http://localhost:3002/api/v2/users/pg
Content-Type: application/json

{
    "username": "sunshinebaby",
    "role": "user",
    "email": "sunshinebaby@example.com",
    "password": "pw123456"
}

### Update a user (Supabase) — replace the UUID with a real id from POST response
PUT http://localhost:3002/api/v2/users/pg/37295dec-11ce-43a0-bec7-7c2339608179
Content-Type: application/json

{
    "username": "Charlie Updated",
    "role": "user"
}

### Delete a user (Supabase) — replace the UUID with a real id from POST response
DELETE http://localhost:3002/api/v2/users/pg/37295dec-11ce-43a0-bec7-7c2339608179